{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI4H Eval Lab",
  "version": "0.6.0",
  "identifier": "org.ai4h.eval-lab",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI4H Eval Lab",
        "label": "main",
        "width": 1360,
        "height": 880,
        "minWidth": 960,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Open model safety evaluation",
    "longDescription": "A local-first desktop application for transparent, reproducible language model safety evaluations.",
    "copyright": "Copyright © 2026 Safe AI for Humanity Foundation",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
